# EcoPulse Backend - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.

# ------------------------------------------------------------------------------
# 🔑 LLM & Speech API Keys
# ------------------------------------------------------------------------------
# Your Google AI Studio Gemini API Key (Required for chat features)
GEMINI_API_KEY=your_gemini_api_key_here

# Your Sarvam AI API Key (Optional, required for STT/TTS voice features)
SARVAM_API_KEY=your_sarvam_api_key_here

# ------------------------------------------------------------------------------
# 📊 Messaging & Telemetry (Kafka)
# ------------------------------------------------------------------------------
# Bootstrap server address for Apache Kafka event streaming
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Target Kafka topic to publish climate events
KAFKA_TOPIC=climate-events

# ------------------------------------------------------------------------------
# 🗄️ Database (Firebase)
# ------------------------------------------------------------------------------
# Absolute or relative path to your Firebase Admin SDK service account key JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-service-account.json

# ------------------------------------------------------------------------------
# 🌐 Server Settings
# ------------------------------------------------------------------------------
# The base URL of the FastAPI backend application
API_URL=http://127.0.0.1:8000

# Application environment mode ('development', 'staging', 'production')
ENVIRONMENT=development

# Enable or disable debug log verbosity and auto-reloader (True/False)
DEBUG=True

# ------------------------------------------------------------------------------
# 🔐 Secrets Management (HashiCorp Vault - Production Only)
# ------------------------------------------------------------------------------
# Address of the Vault server (e.g. https://vault.example.com:8200)
VAULT_ADDR=
# Authentication token to read secrets from Vault
VAULT_TOKEN=
# Path to the KV secret engine folder where keys are stored
VAULT_SECRET_PATH=secret/data/ecopulse
